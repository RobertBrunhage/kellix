---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Kellix',
	description = 'Kellix is a self-hosted Telegram assistant for calories, workouts, goals, and household routines.',
} = Astro.props;

const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImageUrl = new URL('/og.png', Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl.toString()} />
		<meta property="og:image" content={ogImageUrl.toString()} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl.toString()} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: #07111f;
		color: #f5f7fb;
	}

	html,
	body {
		margin: 0;
		min-width: 320px;
		min-height: 100%;
	}

	body {
		background:
			radial-gradient(circle at top, rgba(82, 153, 255, 0.22), transparent 40%),
			radial-gradient(circle at bottom left, rgba(64, 214, 178, 0.16), transparent 30%),
			linear-gradient(180deg, #081221 0%, #04070d 100%);
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}
</style>
