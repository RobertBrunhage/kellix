---

<Layout
	title="Logo exploration"
	description="Logo variations for Kellix."
>
	<main>
		<section class="page">
			<div class="container">
				<p class="eyebrow">Logo exploration</p>
				<h1>Pick a direction.</h1>
				<p class="lead">
					All the concepts, in one place. Each mark is paired with the wordmark
					so you can see how it reads in context.
				</p>
			</div>
		</section>

		<section class="grid-section">
			<div class="container">
				<div class="logo-grid">
					{[...kellix, ...birch].map((logo) => (
						<div class="logo-card">
							<div class="logo-display">
								<svg viewBox="0 0 64 64" class="logo-svg" xmlns="http://www.w3.org/2000/svg" set:html={logo.svg} />
							</div>
							<div class="logo-lockup">
								<svg viewBox="0 0 64 64" class="logo-svg-sm" xmlns="http://www.w3.org/2000/svg" set:html={logo.svg} />
								<span class="logo-wordmark">Kellix</span>
							</div>
							<div class="logo-meta">
								<h3>{logo.name}</h3>
								<p>{logo.note}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.container {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.eyebrow {
		margin: 0 0 16px;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.page {
		padding: 120px 0 40px;
	}

	h1 {
		margin: 0;
		font-family: 'Fraunces', Georgia, serif;
		font-size: clamp(2.8rem, 6vw, 4.5rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: -0.03em;
		color: var(--text);
	}

	.lead {
		max-width: 560px;
		margin: 24px 0 32px;
		font-size: clamp(1rem, 1.6vw, 1.1rem);
		line-height: 1.7;
		color: var(--text-secondary);
	}

	.grid-section {
		padding: 40px 0 120px;
	}

	.logo-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20px;
	}

	.logo-grid[hidden] {
		display: none;
	}

	.logo-card {
		background: #fff;
		border: 1px solid var(--warm-100);
		border-radius: 20px;
		padding: 24px;
		display: flex;
		flex-direction: column;
		transition: border-color 200ms ease, transform 200ms ease;
	}

	.logo-card:hover {
		border-color: var(--warm-200);
		transform: translateY(-2px);
	}

	.logo-display {
		display: flex;
		align-items: center;
		justify-content: center;
		aspect-ratio: 1 / 1;
		background: var(--warm-50);
		border-radius: 14px;
		margin-bottom: 20px;
	}

	.logo-svg {
		width: 56px;
		height: 56px;
		color: var(--text);
	}

	.logo-lockup {
		display: flex;
		align-items: center;
		gap: 10px;
		padding-bottom: 16px;
		border-bottom: 1px solid var(--warm-100);
		margin-bottom: 16px;
	}

	.logo-svg-sm {
		width: 22px;
		height: 22px;
		color: var(--text);
		flex-shrink: 0;
	}

	.logo-wordmark {
		font-family: 'Fraunces', Georgia, serif;
		font-size: 1.3rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--text);
	}

	.logo-meta h3 {
		margin: 0 0 4px;
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--text);
	}

	.logo-meta p {
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.5;
		color: var(--text-secondary);
	}

	@media (max-width: 1024px) {
		.logo-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 768px) {
		.page {
			padding: 80px 0 40px;
		}

		.logo-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 480px) {
		.container {
			padding: 0 16px;
		}

		.logo-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
